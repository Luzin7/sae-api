    "@scalar/fastify-api-reference": "^1.55.3",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.44.2",
    "fastify": "^5.3.3",
    "nanoid": "^5.1.5",
    "postgres": "^3.4.5",
    "zod": "^3.24.4"
  },
